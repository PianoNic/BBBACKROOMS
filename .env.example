PORT=5367

# Cloudflare Realtime TURN — required so webcam streaming works for users
# behind restrictive NATs. Without these the backend falls back to STUN-only,
# which works for most home networks but fails on corporate/symmetric NAT.
#
# Get these at: dash.cloudflare.com -> Realtime -> TURN Server -> create app
TURN_TOKEN_ID=
CLOUDFLARE_API_TOKEN=

# PostgreSQL — optional. Only needed for accounts / XP / coins / cosmetics.
# Omit to run the game without persistence. docker-compose sets DB_HOST=postgres
# automatically; these defaults target a local Postgres for `run.ps1`.
# See docs/persistence.md.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bbb
DB_USER=bbb
DB_PASSWORD=bbb

# OAuth login — optional. Leave a provider's client id/secret empty to hide its
# login button. Register apps per docs/accounts.md and paste the values here.
# Redirect URIs to register:
#   {OAUTH_REDIRECT_BASE}/auth/google/callback
#   {OAUTH_REDIRECT_BASE}/auth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
OAUTH_REDIRECT_BASE=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# 32+ random bytes; stable across restarts in production. Empty = ephemeral (dev).
SESSION_SECRET=
# Set true behind HTTPS in production; must stay false for http://localhost.
SESSION_COOKIE_SECURE=false
