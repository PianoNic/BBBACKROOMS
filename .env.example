PORT=5367

# Cloudflare Realtime TURN — required so webcam streaming works for users
# behind restrictive NATs. Without these the backend falls back to STUN-only,
# which works for most home networks but fails on corporate/symmetric NAT.
#
# Get these at: dash.cloudflare.com -> Realtime -> TURN Server -> create app
TURN_TOKEN_ID=
CLOUDFLARE_API_TOKEN=

# PostgreSQL — optional. Only needed for accounts / XP / coins / cosmetics.
# Omit to run the game without persistence. docker-compose sets DB_HOST=postgres
# automatically; these defaults target a local Postgres for `run.ps1`.
# See docs/persistence.md.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bbb
DB_USER=bbb
DB_PASSWORD=bbb
